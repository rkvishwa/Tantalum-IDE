{
  "name": "tantalum-ide",
  "version": "1.0.0",
  "private": true,
  "description": "Tantalum IDE desktop app with Arduino tooling, Appwrite-backed auth, OTA workflows, and a React + TypeScript UI.",
  "main": "main.js",
  "workspaces": [
    "renderer-react"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "npm run dev --workspace renderer-react -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "node scripts/start-electron.js",
    "start:foreground": "electron .",
    "start:fresh": "npm run build:renderer && npm run start",
    "build:renderer": "npm run build --workspace renderer-react",
    "lint:renderer": "npm run lint --workspace renderer-react",
    "dist": "npm run build:renderer && electron-builder",
    "build:mac": "npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "appwrite": "^13.0.0",
    "bcryptjs": "^2.4.3",
    "electron-store": "^11.0.2",
    "inspire-tree": "^4.3.1",
    "inspire-tree-dom": "^4.0.6",
    "lodash": "^4.17.23",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "serialport": "^12.0.0",
    "uuid": "^9.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.tantalum.ide",
    "productName": "Tantalum IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!resources/arduino-cli/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/arduino-cli/",
        "to": "arduino-cli",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "zip",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "author": "vishva",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.1.2",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  }
}
