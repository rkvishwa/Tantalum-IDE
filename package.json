{
  "name": "tantalum-ide",
  "version": "1.0.0",
  "private": true,
  "description": "Tantalum IDE desktop app with Arduino tooling, cloud-backed auth, OTA workflows, and a React + TypeScript UI.",
  "main": "main.js",
  "workspaces": [
    "renderer-react"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "npm run dev --workspace renderer-react -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "node scripts/start-electron.js",
    "start:foreground": "electron .",
    "start:fresh": "npm run build:renderer && npm run start",
    "build:renderer": "npm run build --workspace renderer-react",
    "lint:renderer": "npm run lint --workspace renderer-react",
    "secret:encrypt-api-key": "node scripts/encrypt-api-key-envelope.mjs",
    "selfhost:set-target": "node scripts/set-appwrite-target.mjs",
    "selfhost:seed": "node scripts/seed-selfhost-appwrite.mjs",
    "migrate:appwrite-project": "node scripts/migrate-appwrite-project.mjs",
    "migrate:api-key-envelopes": "node scripts/migrate-api-key-envelopes.mjs",
    "smoke:agent-gateway": "node scripts/smoke-agent-gateway-policy.mjs",
    "smoke:board-code": "node scripts/smoke-board-code-service.js",
    "smoke:provisioning": "node scripts/smoke-provisioning-service.js",
    "smoke:desktop-auth": "node scripts/smoke-desktop-auth.mjs",
    "smoke:device-gateway-ota-url": "node scripts/smoke-device-gateway-ota-url.mjs",
    "smoke:device-gateway-telemetry": "node scripts/smoke-device-gateway-telemetry.mjs",
    "smoke:firmware-checksum": "node scripts/smoke-firmware-checksum.mjs",
    "smoke:ota-update-modes": "node scripts/smoke-ota-update-modes.mjs",
    "smoke:runtime-ota": "node scripts/smoke-tantalum-runtime-ota.mjs",
    "smoke:secret-envelope": "node scripts/smoke-secret-envelope.mjs",
    "smoke:agent-restore": "node scripts/smoke-agent-restore-points.js",
    "smoke:workspace-sketch": "node scripts/smoke-workspace-sketch-source.js",
    "smoke:cloud-sync": "node scripts/smoke-cloud-sync.js",
    "smoke:opencode": "node scripts/smoke-opencode-runtime.js",
    "icons:generate": "node scripts/generate-tantalum-icons.mjs",
    "dist": "npm run build:renderer && electron-builder",
    "build:mac": "npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@opencode-ai/sdk": "^1.15.6",
    "@vscode/ripgrep": "^1.18.0",
    "appwrite": "^13.0.0",
    "bcryptjs": "^2.4.3",
    "electron-store": "^11.0.2",
    "inspire-tree": "^4.3.1",
    "inspire-tree-dom": "^4.0.6",
    "lodash": "^4.17.23",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "opencode-ai": "^1.15.6",
    "serialport": "^12.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.21.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yauzl": "^2.10.0",
    "yazl": "^3.3.1"
  },
  "build": {
    "appId": "com.tantalum.ide",
    "productName": "Tantalum IDE",
    "asarUnpack": [
      "node_modules/opencode-ai/bin/**",
      "node_modules/opencode-*/**",
      "node_modules/node-pty/prebuilds/**",
      "node_modules/node-pty/build/Release/**"
    ],
    "directories": {
      "output": "dist"
    },
    "icon": "resources/icons/tantalum-icon",
    "protocols": [
      {
        "name": "Tantalum IDE Desktop Login",
        "schemes": [
          "tantalum"
        ]
      }
    ],
    "files": [
      "**/*",
      "!resources/arduino-cli/**/*"
    ],
    "mac": {
      "target": "zip",
      "category": "public.app-category.developer-tools",
      "extraResources": [
        {
          "from": "resources/macos/",
          "to": "macos",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "resources/windows/",
          "to": "windows",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "author": "vishva",
  "license": "ISC",
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.1.2",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  }
}
