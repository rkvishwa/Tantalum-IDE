# Copy to a private shell profile or deployment secret store. Do not commit filled values.

APP_DOMAIN=api.example.com
APPWRITE_ENDPOINT=https://api.example.com/v1
APPWRITE_PROJECT_ID=tantalum
APPWRITE_DATABASE_ID=697b8f660033fffde4be
APPWRITE_VERSION=1.9.0

# Function/runtime secrets. Generate 32-byte KEKs with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
TANTALUM_SECRET_ACTIVE_KEK_VERSION=v1
TANTALUM_SECRET_KEK_V1=
TANTALUM_BOARD_SECRET_KEK_V1=
TANTALUM_ALLOW_LEGACY_RAW_KEYS=false

# Admin API key used only by local scripts such as npm run selfhost:seed.
APPWRITE_API_KEY=

# Optional managed AI seed values.
TANTALUM_MANAGED_PROVIDER_LABEL=Azure AI Foundry
TANTALUM_MANAGED_BASE_URL=
TANTALUM_MANAGED_API_KEY=
TANTALUM_MANAGED_FAST_MODEL=gpt-4.1
TANTALUM_MANAGED_FAST_EDITOR_MODEL=gpt-4.1
TANTALUM_MANAGED_POWER_MODEL=gpt-5.5
TANTALUM_MANAGED_POWER_EDITOR_MODEL=gpt-4.1
TANTALUM_MANAGED_POWER_REASONING_EFFORT=medium
TANTALUM_MANAGED_FAST_CONTEXT_WINDOW=0
TANTALUM_MANAGED_POWER_CONTEXT_WINDOW=0
TANTALUM_MANAGED_REPO_MAP_TOKENS=2048
AGENT_DEFAULT_MONTHLY_CREDITS=500
AGENT_OUTPUT_STYLE=compact

# Optional board detection seed values.
TANTALUM_BOARD_DETECTION_PROVIDER_LABEL=OpenAI-compatible
TANTALUM_BOARD_DETECTION_BASE_URL=https://api.openai.com/v1
TANTALUM_BOARD_DETECTION_API_KEY=
TANTALUM_BOARD_DETECTION_MODEL=gpt-4.1-mini
TANTALUM_BOARD_DETECTION_ENABLED=true

# MQTT is optional for the MVP. HTTPS heartbeat fallback still works when unset.
TANTALUM_MQTT_URL=
TANTALUM_MQTT_HOST=
TANTALUM_MQTT_PORT=8883
TANTALUM_MQTT_PUBLISHER_USERNAME=
TANTALUM_MQTT_PUBLISHER_PASSWORD=
TANTALUM_MQTT_DEVICE_USERNAME=
TANTALUM_MQTT_DEVICE_PASSWORD=
TANTALUM_MQTT_CA_CERT=

# Optional backup encryption on the VM.
BACKUP_ENCRYPTION_PASSPHRASE=
